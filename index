<!-- ═══════════════════════════════════════════════════════ SCRIPT -->
<script>
  // ── Priority filter for cards
  document.querySelectorAll('.filter-btn[data-target="new"]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn[data-target="new"]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      const search = document.getElementById('searchNew').value.toLowerCase();
      applyCardsFilter('new', filter, search);
    });
  });

  document.querySelectorAll('.filter-btn[data-target="improve"]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn[data-target="improve"]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      const search = document.getElementById('searchImprove').value.toLowerCase();
      applyRowsFilter('improve', filter, search);
    });
  });

  function searchCards(target, value) {
    const activeBtn = document.querySelector(`.filter-btn[data-target="${target}"].active`);
    const priority = activeBtn ? activeBtn.dataset.filter : 'all';
    applyCardsFilter(target, priority, value.toLowerCase());
  }

  function searchRows(target, value) {
    const activeBtn = document.querySelector(`.filter-btn[data-target="${target}"].active`);
    const priority = activeBtn ? activeBtn.dataset.filter : 'all';
    applyRowsFilter(target, priority, value.toLowerCase());
  }

  function applyCardsFilter(target, priority, search) {
    const cards = document.querySelectorAll('#cardsNew .card');
    let visible = 0;
    cards.forEach(card => {
      const matchPriority = priority === 'all' || card.dataset.priority === priority;
      const text = card.innerText.toLowerCase();
      const matchSearch = search === '' || text.includes(search);
      if (matchPriority && matchSearch) { card.classList.remove('hidden'); visible++; }
      else card.classList.add('hidden');
    });
    document.getElementById('emptyNew').style.display = visible === 0 ? 'block' : 'none';
  }

  function applyRowsFilter(target, priority, search) {
    const rows = document.querySelectorAll('#tableImprove tbody tr');
    let visible = 0;
    rows.forEach(row => {
      const matchPriority = priority === 'all' || row.dataset.priority === priority;
      const text = row.innerText.toLowerCase();
      const matchSearch = search === '' || text.includes(search);
      if (matchPriority && matchSearch) { row.classList.remove('hidden'); visible++; }
      else row.classList.add('hidden');
    });
    document.getElementById('emptyImprove').style.display = visible === 0 ? 'block' : 'none';
  }
</script>
</body>
</html>
